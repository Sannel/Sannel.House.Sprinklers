@page "/history"
@attribute [Authorize]
@inject IMediator Mediator

<PageTitle>Run History</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Run History</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6">
        <MudDatePicker Label="From" @bind-Date="_from" />
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudDatePicker Label="To" @bind-Date="_to" />
    </MudItem>
    <MudItem xs="12">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadHistory">Load</MudButton>
    </MudItem>
</MudGrid>

@if (_runs is null)
{
    <MudText>Select a date range and click Load.</MudText>
}
else
{
    <MudTable Items="_runs" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Zone</MudTh>
            <MudTh>Run Length</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ActionDate.ToString("g")</MudTd>
            <MudTd>@(context.StationName ?? context.StationId.ToString())</MudTd>
            <MudTd>@context.RunLength?.ToString(@"mm\:ss")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private DateTime? _from = DateTime.Today.AddDays(-7);
    private DateTime? _to = DateTime.Today;
    private IEnumerable<ZoneRunDto>? _runs;

    private async Task LoadHistory()
    {
        if (_from is null || _to is null) return;
        var from = DateOnly.FromDateTime(_from.Value);
        var to = DateOnly.FromDateTime(_to.Value);
        _runs = await Mediator.Send(new GetRunHistoryQuery(from, to));
    }
}
