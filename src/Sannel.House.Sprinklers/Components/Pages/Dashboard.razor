@page "/"
@attribute [Authorize]
@inject IMediator Mediator
@inject HubMessageClient HubClient
@implements IAsyncDisposable

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

@if (_status is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Status</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChip Color="@(_status.IsRunning ? Color.Success : Color.Default)" T="string">
                        @(_status.IsRunning ? "Running" : "Idle")
                    </MudChip>
                    @if (_status.IsRunning)
                    {
                        <MudText Class="mt-2">Zone: @(_status.ZoneInfo?.Name ?? _status.ZoneInfo?.ZoneId.ToString())</MudText>
                        <MudText>Time left: @_status.TimeLeft?.ToString(@"mm\:ss")</MudText>
                        <MudText>Queued: @_status.QueuedZoneCount</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (_status.IsRunning)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="StopAll">Stop All</MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>

        @if (_zones is not null)
        {
            <MudItem xs="12" sm="6" md="8">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Run Zones</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudSelect @bind-Value="_selectedZoneId" T="byte" Label="Zone" Variant="Variant.Outlined" Style="min-width:180px">
                                @foreach (var zone in _zones)
                                {
                                    <MudSelectItem Value="zone.ZoneId">
                                        @(string.IsNullOrEmpty(zone.Name) ? $"Zone {zone.ZoneId}" : zone.Name)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            <MudNumericField @bind-Value="_selectedMinutes" Label="Minutes" Min="1" Max="480"
                                             Variant="Variant.Outlined" Style="width:100px" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                       OnClick="AddToQueue">Add to Queue</MudButton>
                        </MudStack>

                        @if (_zoneQueue.Count > 0)
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Queue (@_zoneQueue.Count zones)</MudText>
                            @foreach (var item in _zoneQueue.ToList())
                            {
                                var entry = item;
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small">
                                        @(string.IsNullOrEmpty(entry.Zone.Name) ? $"Zone {entry.Zone.ZoneId}" : entry.Zone.Name) — @entry.Minutes min
                                    </MudChip>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   Color="Color.Error" OnClick="() => _zoneQueue.Remove(entry)" />
                                </MudStack>
                            }
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   Disabled="_zoneQueue.Count == 0"
                                   OnClick="StartQueue">Start Queue</MudButton>
                        @if (_zoneQueue.Count > 0)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="() => _zoneQueue.Clear()">Clear</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private StatusDto? _status;
    private IEnumerable<ZoneInfoDto>? _zones;
    private byte _selectedZoneId;
    private int _selectedMinutes = 10;
    private readonly List<QueueEntry> _zoneQueue = [];

    protected override async Task OnInitializedAsync()
    {
        _zones = await Mediator.Send(new GetZonesQuery());
        _selectedZoneId = _zones?.FirstOrDefault()?.ZoneId ?? 1;

        await RefreshStatus();

        HubClient.OnStart += HandleStart;
        HubClient.OnProgress += HandleProgress;
        HubClient.OnStop += HandleStop;
    }

    private async Task RefreshStatus()
    {
        _status = await Mediator.Send(new GetStatusQuery());
    }

    private void HandleStart(StationStartMessage msg)
    {
        if (_status is null) return;
        _status.IsRunning = true;
        _status.ZoneInfo = _zones?.FirstOrDefault(z => z.ZoneId == msg.ZoneId);
        _status.TotalTime = msg.Duration;
        _status.TimeLeft = msg.Duration;
        InvokeAsync(StateHasChanged);
    }

    private void HandleProgress(StationProgressMessage msg)
    {
        if (_status is null) return;
        _status.TimeLeft = msg.TimeLeft;
        _status.TotalTime = msg.RunLength;
        InvokeAsync(StateHasChanged);
    }

    private void HandleStop(StationStopMessage msg)
    {
        if (_status is null) return;
        _status.IsRunning = false;
        _status.ZoneInfo = null;
        _status.TimeLeft = null;
        _status.TotalTime = null;
        _status.QueuedZoneCount = 0;
        InvokeAsync(StateHasChanged);
    }

    private async Task StopAll()
    {
        await Mediator.Send(new StopAllCommand());
        await RefreshStatus();
    }

    private void AddToQueue()
    {
        var zone = _zones?.FirstOrDefault(z => z.ZoneId == _selectedZoneId);
        if (zone is null) return;
        _zoneQueue.Add(new QueueEntry(zone, _selectedMinutes));
    }

    private async Task StartQueue()
    {
        if (_zoneQueue.Count == 0) return;
        var requests = _zoneQueue
            .Select(e => new ZoneStartRequestDto { ZoneId = e.Zone.ZoneId, Length = TimeSpan.FromMinutes(e.Minutes) })
            .ToList();
        _zoneQueue.Clear();
        await Mediator.Send(new EnqueueZonesCommand(requests));
    }

    public ValueTask DisposeAsync()
    {
        HubClient.OnStart -= HandleStart;
        HubClient.OnProgress -= HandleProgress;
        HubClient.OnStop -= HandleStop;
        return ValueTask.CompletedTask;
    }

    private sealed record QueueEntry(ZoneInfoDto Zone, int Minutes);
}
