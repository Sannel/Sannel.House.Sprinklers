@page "/zones"
@attribute [Authorize]
@inject IMediator Mediator
@inject IDialogService DialogService

<PageTitle>Zones</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Zones</MudText>

@if (_zones is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_zones" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Color</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ZoneId</MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                <MudChip Style="@($"background-color:{context.Color}")" T="string">@context.Color</MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                               OnClick="() => EditZone(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success"
                               OnClick="() => RunZone(context)" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_editDialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Zone @_editZone?.ZoneId</MudText>
    </TitleContent>
    <DialogContent>
        @if (_editZone is not null)
        {
            <MudTextField @bind-Value="_editZone.Name" Label="Name" Variant="Variant.Outlined" />
            <MudColorPicker @bind-Text="_editZone.Color" Label="Color" Variant="Variant.Outlined"
                            ColorPickerMode="ColorPickerMode.HEX" Class="mt-4" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelEdit">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveZone">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IEnumerable<ZoneInfoDto>? _zones;
    private ZoneInfoDto? _editZone;
    private bool _editDialogOpen;

    protected override async Task OnInitializedAsync()
    {
        _zones = await Mediator.Send(new GetZonesQuery());
    }

    private void EditZone(ZoneInfoDto zone)
    {
        _editZone = new ZoneInfoDto { ZoneId = zone.ZoneId, Name = zone.Name, Color = zone.Color };
        _editDialogOpen = true;
    }

    private void CancelEdit()
    {
        _editDialogOpen = false;
    }

    private async Task SaveZone()
    {
        if (_editZone is null) return;
        await Mediator.Send(new UpdateZoneCommand(_editZone));
        _zones = await Mediator.Send(new GetZonesQuery());
        _editDialogOpen = false;
    }

    private async Task RunZone(ZoneInfoDto zone)
    {
        await Mediator.Send(new EnqueueZonesCommand(
        [
            new ZoneStartRequestDto { ZoneId = zone.ZoneId, Length = TimeSpan.FromMinutes(5) }
        ]));
    }
}
